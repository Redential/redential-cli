{
  "name": "@redential/cli",
  "version": "0.1.0",
  "description": "Local, metadata-only proof bundles from git history. Source code never leaves your machine.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "redential": "dist/cli.js"
  },
  "files": [
    "dist",
    "signatures",
    "taxonomy.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
