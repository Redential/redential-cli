{
  "name": "@redential/cli",
  "version": "0.5.0",
  "description": "Local, metadata-only proof bundles from git history. Source code never leaves your machine.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "redential": "dist/cli.js"
  },
  "files": [
    "dist",
    "signatures",
    "taxonomy.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Redential/redential-cli.git"
  },
  "homepage": "https://github.com/Redential/redential-cli#readme",
  "bugs": {
    "url": "https://github.com/Redential/redential-cli/issues"
  },
  "keywords": [
    "cli",
    "git",
    "credential-verification",
    "proof-of-work",
    "developer-portfolio",
    "privacy"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude \"**/test/slow/**\"",
    "test:slow": "vitest run test/slow",
    "prepublishOnly": "npm test && npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "typescript": "^5.6.0"
  },
  "devDependencies": {
    "vitest": "^2.1.0"
  }
}
